{
  "info": {
    "name": "anvilkit-auth-template",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url_auth",
      "value": "http://localhost:8080"
    },
    {
      "key": "base_url_admin",
      "value": "http://localhost:8081"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "tenant_id",
      "value": ""
    },
    {
      "key": "register_email",
      "value": "register@example.com"
    },
    {
      "key": "verification_otp",
      "value": "123456"
    },
    {
      "key": "verification_wrong_otp",
      "value": "000000"
    },
    {
      "key": "magic_link_token",
      "value": "replace-with-token-from-email"
    },
    {
      "key": "magic_link_state",
      "value": "replace-with-state-from-email-link"
    }
  ],
  "item": [
    {
      "name": "bootstrap",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{base_url_auth}}/v1/bootstrap",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tenant_name\": \"postman-tenant\",\n  \"owner_email\": \"postman@example.com\",\n  \"owner_password\": \"Passw0rd!\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const b = pm.response.json();",
              "pm.test('envelope code=0', ()=> pm.expect(b.code).to.eql(0));",
              "pm.test('tenant id exists', ()=> pm.expect(b.data.tenant.id).to.be.a('string').and.not.empty);",
              "pm.collectionVariables.set('tenant_id', b.data.tenant.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{base_url_auth}}/api/v1/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{register_email}}\",\n  \"password\": \"Passw0rd!\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const b = pm.response.json();",
              "pm.test('status accepted', ()=> pm.expect(pm.response.code).to.eql(202));",
              "pm.test('envelope code=0', ()=> pm.expect(b.code).to.eql(0));",
              "pm.test('check-email message', ()=> pm.expect(b.message).to.eql('registration accepted, please check your email for verification'));",
              "pm.test('has user id', ()=> pm.expect(b.data.user.id).to.be.a('string'));"
            ]
          }
        }
      ]
    },
    {
      "name": "resend-verification",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{base_url_auth}}/api/v1/auth/resend-verification",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{register_email}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const b = pm.response.json();",
              "pm.test('status accepted', ()=> pm.expect(pm.response.code).to.eql(202));",
              "pm.test('envelope code=0', ()=> pm.expect(b.code).to.eql(0));",
              "pm.test('resend message', ()=> pm.expect(b.data.message).to.eql('Verification email sent'));",
              "pm.test('retry_after 90', ()=> pm.expect(b.data.retry_after).to.eql(90));"
            ]
          }
        }
      ]
    },
    {
      "name": "verify-email (otp)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{base_url_auth}}/api/v1/auth/verify-email",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{register_email}}\",\n  \"otp\": \"{{verification_otp}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const b = pm.response.json();",
              "pm.test('status ok', ()=> pm.expect(pm.response.code).to.eql(200));",
              "pm.test('envelope code=0', ()=> pm.expect(b.code).to.eql(0));",
              "pm.test('verification success message', ()=> pm.expect(b.data.message).to.eql('Email verified successfully'));"
            ]
          }
        }
      ]
    },
    {
      "name": "verify-email (otp invalid)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{base_url_auth}}/api/v1/auth/verify-email",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{register_email}}\",\n  \"otp\": \"{{verification_wrong_otp}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const b = pm.response.json();",
              "pm.test('status bad request', ()=> pm.expect(pm.response.code).to.eql(400));",
              "pm.test('envelope bad_request', ()=> pm.expect(b.code).to.eql(1001));",
              "pm.test('reason invalid_otp', ()=> pm.expect(b.data.reason).to.eql('invalid_otp'));"
            ]
          }
        }
      ]
    },
    {
      "name": "verify-magic-link",
      "request": {
        "method": "GET",
        "url": "{{base_url_auth}}/api/v1/auth/verify-magic-link?token={{magic_link_token}}&state={{magic_link_state}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is browser-flow compatible', ()=> pm.expect([200,302,400,410]).to.include(pm.response.code));"
            ]
          }
        }
      ]
    },
    {
      "name": "login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{base_url_auth}}/v1/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"postman@example.com\",\n  \"password\": \"Passw0rd!\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const b = pm.response.json();",
              "pm.test('envelope code=0', ()=> pm.expect(b.code).to.eql(0));",
              "pm.test('has access token', ()=> pm.expect(b.data.access_token).to.be.a('string'));",
              "pm.test('has refresh token', ()=> pm.expect(b.data.refresh_token).to.be.a('string'));",
              "pm.collectionVariables.set('access_token', b.data.access_token);",
              "pm.collectionVariables.set('refresh_token', b.data.refresh_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "refresh",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{base_url_auth}}/v1/auth/refresh",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const b = pm.response.json();",
              "pm.test('envelope code=0', ()=> pm.expect(b.code).to.eql(0));",
              "pm.collectionVariables.set('access_token', b.data.access_token);",
              "pm.collectionVariables.set('refresh_token', b.data.refresh_token);",
              "if (b.data && b.data.tenant_id) { pm.collectionVariables.set('tenant_id', b.data.tenant_id); }"
            ]
          }
        }
      ]
    },
    {
      "name": "logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{base_url_auth}}/v1/auth/logout",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const b = pm.response.json();",
              "pm.test('envelope code=0', ()=> pm.expect(b.code).to.eql(0));"
            ]
          }
        }
      ]
    },
    {
      "name": "switch_tenant",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"tenant_id\": \"{{tenant_id}}\"}"
        },
        "url": {
          "raw": "{{base_url_auth}}/v1/auth/switch_tenant",
          "host": [
            "{{base_url_auth}}"
          ],
          "path": [
            "v1",
            "auth",
            "switch_tenant"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('access_token', json.data.access_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "admin me roles",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": "{{base_url_admin}}/api/v1/admin/tenants/{{tenant_id}}/me/roles"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const b = pm.response.json();",
              "pm.test('envelope code=0', ()=> pm.expect(b.code).to.eql(0));"
            ]
          }
        }
      ]
    }
  ]
}
