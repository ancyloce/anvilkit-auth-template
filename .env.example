# Database
DB_DSN=postgres://postgres:postgres@pg:5432/auth?sslmode=disable

# Redis
REDIS_ADDR=redis:6379

# JWT
JWT_ISSUER=anvilkit-auth
JWT_AUDIENCE=anvilkit-clients
JWT_SECRET=dev-secret-change-me

# Auth Public Base URL
AUTH_PUBLIC_BASE_URL=http://localhost:8080
ACCESS_TTL_MIN=15
REFRESH_TTL_HOURS=168

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# Email Queue
EMAIL_QUEUE_NAME=email:send
EMAIL_QUEUE_POP_TIMEOUT_SEC=5
EMAIL_QUEUE_BACKLOG_POLL_SEC=15
EMAIL_WEBHOOK_ADDR=:8082
EMAIL_METRICS_ADDR=:9090
EMAIL_WEBHOOK_SECRET=dev-email-webhook-secret

# Email SMTP
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Anvilkit Auth

# Monitoring
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
ALERT_EMAIL_TO=alerts@example.com
ALERT_EMAIL_FROM=alerts@anvilkit.local
ALERT_SMTP_SMARTHOST=mailpit:1025
ALERT_SMTP_AUTH_USERNAME=
ALERT_SMTP_AUTH_PASSWORD=
ALERT_SMTP_REQUIRE_TLS=false
